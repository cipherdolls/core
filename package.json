    "@elysiajs/swagger": "^1.2.0",
    "@prisma/client": "^6.8.2",
    "aedes": "^1.0.2",
    "bullmq": "^5.34.0",
    "elysia": "^1.2.25",
    "ethers": "^6.13.4",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.15.1",
    "sharp": "^0.34.5",
    "websocket-stream": "^5.5.2",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "bun run prisma/seed/index.ts"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
